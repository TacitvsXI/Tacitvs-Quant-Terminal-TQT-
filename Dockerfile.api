FROM python:3.12-slim

WORKDIR /app

# Single COPY to avoid Railway layer cache issues with selective copies
COPY . .

RUN pip install --no-cache-dir -r apps/api/requirements.txt

# Verify core/data is present
RUN ls /app/core/data/__init__.py && echo "core/data OK"

ENV PYTHONPATH=/app:/app/apps/api

CMD ["python", "/app/apps/api/start.py"]
